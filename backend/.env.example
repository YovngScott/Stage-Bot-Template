# ── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
# Carpeta base de las sesiones de WhatsApp — cada tenant tiene su propia
# subcarpeta (${BAILEYS_AUTH_DIR}/<slug>/). En Fly.io, monta un volumen aquí
# (ver fly.toml) para que las sesiones sobrevivan a un redeploy.
BAILEYS_AUTH_DIR=./.baileys_auth

# ── IA para responder (GRATIS) ───────────────────────────────────────────────
AI_PROVIDER=groq
# Groq (recomendado) — https://console.groq.com/keys (sin tarjeta)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini (alternativa) — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-flash-lite-latest

# ── Supabase (proyecto COMPARTIDO por todos los tenants) ────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# Service role key (solo backend, NUNCA exponer en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Google Calendar ─────────────────────────────────────────────────────────
# UNA sola app OAuth de Google Cloud sirve para TODOS los tenants — cada uno
# conecta SU PROPIA cuenta desde su dashboard ("Conectar con Google"); el
# refresh_token de cada uno se guarda por separado (google_oauth_tokens, por
# tenant_id). Crea un "OAuth client ID" tipo Web application en Google Cloud
# Console y agrega esta URL EXACTA (tu dominio del backend +
# /api/calendar/oauth-callback) como "Authorized redirect URI".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/oauth-callback

# ── Control remoto (Stage AI Labs — owner console) ──────────────────────────
# Secreto compartido para que el Client Manager de Stage AI Labs pueda
# encender/apagar CUALQUIER tenant remotamente (ej. cliente sin pagar). Genera
# un valor random largo (ej. `openssl rand -hex 32`) y pon el MISMO valor en
# el campo "Bot secret" de cada cliente en Client Manager (STAGE-DASH).
PLATFORM_ADMIN_SECRET=

# ── Recordatorios y reporte diario automáticos por WhatsApp ─────────────────
# Hora GLOBAL (UTC) para todos los tenants — cada uno recibe su
# recordatorio/reporte en el texto formateado según SU zona horaria
# (config/tenants/<slug>.json → zonaHoraria), pero el cron dispara a la misma
# hora UTC para todos por simplicidad.
RECORDATORIO_CITAS_HORA=09:00
REPORTE_DIARIO_HORA=20:00

# ── Nada de ADMIN_EMAILS aquí ────────────────────────────────────────────────
# Quién puede administrar CADA cliente vive en su propio archivo
# config/tenants/<slug>.json (campo "adminEmails"), no en una variable de
# entorno global — así el dueño de un negocio no puede gestionar el de otro.
