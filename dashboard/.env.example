# Supabase — proyecto COMPARTIDO por todos los clientes. Usar SOLO la anon
# key (es pública por diseño); el aislamiento entre clientes lo hace RLS
# (tabla tenant_admins), no el secreto de esta clave.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Slug de ESTE cliente (debe matchear config/tenants/<slug>.json en el
# backend). Cada cliente tiene su propio dashboard desplegado (mismo código,
# esta variable distinta), aunque el backend y el Supabase sean compartidos.
VITE_TENANT_SLUG=mi-cliente

# URL del backend multi-cliente (una sola para todos, ej. tu app de Fly.io).
VITE_API_URL=http://localhost:3000

# Marca (opcional) — nombre y subtítulo que se muestran en la barra lateral.
VITE_NEGOCIO_NOMBRE=Mi Negocio
VITE_NEGOCIO_SUBTITULO=Consola del bot
